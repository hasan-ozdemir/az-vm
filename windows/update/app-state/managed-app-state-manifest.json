{
  "version": 1,
  "apps": [
    {
      "id": "google-chrome",
      "displayName": "Google Chrome",
      "installTask": "02-check-install-chrome",
      "stateMode": "tracked-safe-baseline",
      "machineDirectories": [
        "{publicChromeRoot}",
        "{publicChromeRoot}\\{businessProfileDirectory}",
        "{publicChromeRoot}\\{personalProfileDirectory}"
      ],
      "notes": "Shared public Chrome profile roots are safe to replay in tracked state. Deeper profile content remains local-overlay only."
    },
    {
      "id": "powershell-core",
      "displayName": "PowerShell 7",
      "installTask": "101-install-powershell-core",
      "stateMode": "runtime-owned"
    },
