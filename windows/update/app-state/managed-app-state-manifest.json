        "AppData\\Roaming\\Code\\User"
      ],
      "profileFiles": [
        {
          "relativePath": "AppData\\Roaming\\Code\\User\\settings.json",
          "content": "{}\r\n"
        },
        {
          "relativePath": "AppData\\Roaming\\Code\\User\\keybindings.json",
          "content": "[]\r\n"
        }
      ]
    },
