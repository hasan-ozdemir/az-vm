# az-vm unified .env template
# Runtime precedence: CLI override > .env value > script default.

# Select deployment platform for auto mode: windows | linux
# Leave empty to choose interactively in interactive mode.
VM_OS_TYPE=

# Core naming
SERVER_NAME=
AZ_LOCATION=austriaeast
NAMING_TEMPLATE_ACTIVE=regional_v1

# Active names (optional explicit overrides; leave empty to resolve from templates)
RESOURCE_GROUP=
VNET_NAME=
SUBNET_NAME=
NSG_NAME=
NSG_RULE_NAME=
PUBLIC_IP_NAME=
NIC_NAME=
VM_NAME=
VM_DISK_NAME=

# Regional naming templates
RESOURCE_GROUP_TEMPLATE=rg-{SERVER_NAME}-{REGION_CODE}
VNET_NAME_TEMPLATE=net-{SERVER_NAME}-{REGION_CODE}-n{N}
SUBNET_NAME_TEMPLATE=subnet-{SERVER_NAME}-{REGION_CODE}-n{N}
NSG_NAME_TEMPLATE=nsg-{SERVER_NAME}-{REGION_CODE}-n{N}
NSG_RULE_NAME_TEMPLATE=nsgrule-{SERVER_NAME}-{REGION_CODE}-n{N}
PUBLIC_IP_NAME_TEMPLATE=ip-{SERVER_NAME}-{REGION_CODE}-n{N}
NIC_NAME_TEMPLATE=nic-{SERVER_NAME}-{REGION_CODE}-n{N}
VM_NAME_TEMPLATE=vm-{SERVER_NAME}-{REGION_CODE}-n{N}
VM_DISK_NAME_TEMPLATE=disk-{SERVER_NAME}-{REGION_CODE}-n{N}

# VM properties (generic)
VM_IMAGE=
VM_STORAGE_SKU=StandardSSD_LRS
VM_SIZE=Standard_B2as_v2
VM_DISK_SIZE_GB=
PRICE_HOURS=730
VM_USER=manager
VM_PASS=<CHANGE_ME_STRONG_PASSWORD>
VM_ASSISTANT_USER=assistant
VM_ASSISTANT_PASS=<runtime-secret>
SSH_PORT=444
AZ_COMMAND_TIMEOUT_SECONDS=1800
SSH_CONNECT_TIMEOUT_SECONDS=30
SSH_TASK_TIMEOUT_SECONDS=180

# Task catalogs (relative to repo root or absolute)
VM_INIT_TASK_DIR=
VM_UPDATE_TASK_DIR=

# Task outcome handling: continue | strict
# Linux uses this value directly.
# Windows update flow is forced to strict.
TASK_OUTCOME_MODE=continue

# SSH transport
# Linux uses this value directly.
# Windows update flow is forced to single-attempt (1).
SSH_MAX_RETRIES=3
PYSSH_CLIENT_PATH=

# NSG + OS inbound TCP ports (comma-separated)
TCP_PORTS=80,443,444,8444,3389,389,5173,3000,3001,8080,5432,3306,6837,4000,4001,5000,5001,6000,6001,6060,7000,7001,7070,8000,8001,9000,9001,9090,2222,3333,4444,5555,6666,7777,8888,9999,11434

# Optional platform-specific fallbacks (used only when generic keys above are empty)
WIN_SERVER_NAME=examplevm
LIN_SERVER_NAME=otherexamplevm
WIN_VM_IMAGE=MicrosoftWindowsDesktop:office-365:win11-25h2-avd-m365:latest
LIN_VM_IMAGE=Canonical:ubuntu-24_04-lts:server:latest
WIN_VM_DISK_SIZE_GB=128
LIN_VM_DISK_SIZE_GB=40
WIN_VM_INIT_TASK_DIR=windows/init
WIN_VM_UPDATE_TASK_DIR=windows/update
LIN_VM_INIT_TASK_DIR=linux/init
LIN_VM_UPDATE_TASK_DIR=linux/update
