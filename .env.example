# az-vm unified .env template
# Runtime precedence: CLI override > .env value > script default.

# Active selections
# SELECTED_* values are the committed active-selection contract.
# When these values are complete, create --auto can run end-to-end without repeating them on the CLI.
SELECTED_VM_OS=windows
# SELECTED_VM_NAME is the actual Azure VM name and the naming seed for derived managed resource names.
# Set it explicitly for unattended auto flows.
SELECTED_VM_NAME=
# SELECTED_RESOURCE_GROUP is the active existing-target default for update/connect/exec/task/do/delete/move/resize/set.
# Leave it blank when no managed VM has been created or configured yet.
SELECTED_RESOURCE_GROUP=
# SELECTED_COMPANY_NAME controls the default Google Chrome profile directory for repo-managed Windows business web shortcuts.
# Repo-managed Chrome profile-directory values are normalized to lowercase.
# Example: SELECTED_COMPANY_NAME=<organization-name> -> --profile-directory="orgprofile"
SELECTED_COMPANY_NAME=
SELECTED_COMPANY_WEB_ADDRESS=<https-url>
SELECTED_COMPANY_EMAIL_ADDRESS=<email>
SELECTED_EMPLOYEE_EMAIL_ADDRESS=<email>
SELECTED_EMPLOYEE_FULL_NAME=<person-name>
# Optional default Azure subscription id.
# Resolution precedence is: CLI --subscription-id/-s > .env SELECTED_AZURE_SUBSCRIPTION_ID > active Azure CLI subscription.
# If CLI --subscription-id/-s is provided successfully, az-vm writes that value back into .env.
SELECTED_AZURE_SUBSCRIPTION_ID=
SELECTED_AZURE_REGION=

# Regional naming templates
RESOURCE_GROUP_TEMPLATE=rg-{SELECTED_VM_NAME}-{REGION_CODE}-g{N}
VNET_NAME_TEMPLATE=net-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}
SUBNET_NAME_TEMPLATE=subnet-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}
NSG_NAME_TEMPLATE=nsg-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}
NSG_RULE_NAME_TEMPLATE=nsg-rule-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}
PUBLIC_IP_NAME_TEMPLATE=ip-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}
NIC_NAME_TEMPLATE=nic-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}
VM_DISK_NAME_TEMPLATE=disk-{SELECTED_VM_NAME}-{REGION_CODE}-n{N}

# VM properties (shared)
VM_STORAGE_SKU=StandardSSD_LRS
VM_SECURITY_TYPE=
# Common feature toggles for create/update post-deploy behavior.
VM_ENABLE_HIBERNATION=true
VM_ENABLE_NESTED_VIRTUALIZATION=true
VM_ENABLE_SECURE_BOOT=true
VM_ENABLE_VTPM=true
VM_PRICE_COUNT_HOURS=730
# App-wide operator identity, secrets, and reusable overrides belong in .env.
# Task-specific literals should stay in the owning task script's top config block.
VM_ADMIN_USER=manager
VM_ADMIN_PASS=<CHANGE_ME_STRONG_ADMIN_PASSWORD>
VM_ASSISTANT_USER=assistant
VM_ASSISTANT_PASS=<CHANGE_ME_STRONG_ASSISTANT_PASSWORD>
VM_SSH_PORT=444
VM_RDP_PORT=3389
AZURE_COMMAND_TIMEOUT_SECONDS=1800
SSH_CONNECT_TIMEOUT_SECONDS=30
SSH_TASK_TIMEOUT_SECONDS=180

# VM properties (platform-specific; required)
WIN_VM_IMAGE=MicrosoftWindowsDesktop:office-365:win11-25h2-avd-m365:latest
WIN_VM_SIZE=Standard_B4as_v2
WIN_VM_DISK_SIZE_GB=128
LIN_VM_IMAGE=Canonical:ubuntu-24_04-lts:server:latest
LIN_VM_SIZE=Standard_B2as_v2
LIN_VM_DISK_SIZE_GB=40

# Task catalogs (relative to repo root or absolute)
WIN_VM_INIT_TASK_DIR=windows/init
WIN_VM_UPDATE_TASK_DIR=windows/update
LIN_VM_INIT_TASK_DIR=linux/init
LIN_VM_UPDATE_TASK_DIR=linux/update

# Task outcome handling: continue | strict
# continue: log task failure and continue with the next task.
# strict: stop the current task stage on the first failure.
VM_TASK_OUTCOME_MODE=continue

# SSH transport
# Linux uses this value directly.
# Windows update flow is forced to single-attempt (1).
SSH_MAX_RETRIES=3
# Repo-relative path is resolved from the repository root when the value is not absolute.
PYSSH_CLIENT_PATH=tools/pyssh/ssh_client.py

# NSG + OS inbound TCP ports (comma-separated, extra ports only)
# VM_SSH_PORT and VM_RDP_PORT are merged automatically into the effective port set.
TCP_PORTS=80,443,8444,389,5173,3000,3001,8080,5432,3306,6837,4000,4001,5000,5001,6000,6001,6060,7000,7001,7070,8000,8001,9000,9001,9090,2222,3333,4444,5555,6666,7777,8888,9999,11434
