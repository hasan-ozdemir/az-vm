# Ignore sensitive runtime environment files
.env
**/.env

# Ignore logs and transcripts
*.log
*.tmp
az-vm-log-*.txt
az-vm-win-e2e-*.log
_tmp_test.txt

# Ignore temp runtime artifacts
.tmp/
tmp/
tmp-logs/

# Ignore local-only stage task trees
windows/update/app-states/**
linux/update/app-states/**
windows/init/local/**
!windows/init/local/
!windows/init/local/.gitkeep
!windows/init/local/disabled/
windows/init/local/disabled/**
!windows/init/local/disabled/.gitkeep
windows/update/local/**
!windows/update/local/
!windows/update/local/.gitkeep
!windows/update/local/disabled/
windows/update/local/disabled/**
!windows/update/local/disabled/.gitkeep
linux/init/local/**
!linux/init/local/
!linux/init/local/.gitkeep
!linux/init/local/disabled/
linux/init/local/disabled/**
!linux/init/local/disabled/.gitkeep
linux/update/local/**
!linux/update/local/
!linux/update/local/.gitkeep
!linux/update/local/disabled/
linux/update/local/disabled/**
!linux/update/local/disabled/.gitkeep

# Ignore downloaded SSH helper binaries/vendors
tools/putty/*.exe
tools/winscp/*.exe
tools/pyssh/vendor/
tools/pyssh/.venv/
tools/pyssh/__pycache__/
tools/pyssh/*.pyc

# Legacy folders removed from active architecture
co-vm/
lin-vm/
win-vm/

# OS/editor noise
Thumbs.db
.DS_Store
