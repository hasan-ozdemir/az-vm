# Ignore sensitive runtime environment files
.env
**/.env

# Ignore logs and transcripts
*.log
*.tmp
az-vm-log-*.txt
az-vm-win-e2e-*.log
_tmp_test.txt

# Ignore temp runtime artifacts
.tmp/
tmp/
tmp-logs/

# Ignore local-only Windows task extensions and assets
windows/update/8[01]-*.ps1
windows/update/90-*.ps1
windows/update/disabled/99-*.ps1
windows/update/local-private-assets/

# Ignore downloaded SSH helper binaries/vendors
tools/putty/*.exe
tools/winscp/*.exe
tools/pyssh/vendor/
tools/pyssh/.venv/
tools/pyssh/__pycache__/
tools/pyssh/*.pyc

# Legacy folders removed from active architecture
co-vm/
lin-vm/
win-vm/

# OS/editor noise
Thumbs.db
.DS_Store
